@page "/settings"
@using CheapBarcodes.Services
@inject ScanApiClient ScanApi
@inject ScanUploadQueue UploadQueue

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-4">
    <MudCard Class="pa-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="Icons.Material.Filled.CloudUpload" Class="mr-2" />
                    API Settings
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Configure an endpoint to post scans to. Leave the URL empty to keep the app fully offline.
                    The auth header is only sent over HTTPS.
                </MudText>

                <MudTextField @bind-Value="uploadOptions.BaseUrl"
                              Label="API URL"
                              Placeholder="https://example.com/scans"
                              Variant="Variant.Outlined"
                              Immediate="true" />

                <MudTextField @bind-Value="uploadOptions.AuthHeaderName"
                              Label="Auth header name (optional)"
                              Placeholder="Authorization or X-Api-Key"
                              Variant="Variant.Outlined" />

                <MudTextField @bind-Value="uploadOptions.AuthHeaderValue"
                              Label="Auth header value (optional)"
                              Placeholder="Bearer eyJ... or key value"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password" />

                <MudSwitch T="bool"
                           @bind-Value="uploadOptions.AutoPost"
                           Color="Color.Primary"
                           Label="Automatically post every scan" />

                <MudDivider Class="my-2" />

                <MudText Typo="Typo.subtitle1">OAuth (optional)</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    When a token endpoint is set, client-credentials OAuth replaces the auth header.
                    Requires HTTPS.
                </MudText>

                <MudTextField @bind-Value="uploadOptions.TokenEndpoint"
                              Label="Token endpoint"
                              Placeholder="https://login.example.com/oauth2/token"
                              Variant="Variant.Outlined" />

                <MudTextField @bind-Value="uploadOptions.ClientId"
                              Label="Client id"
                              Variant="Variant.Outlined" />

                <MudTextField @bind-Value="uploadOptions.ClientSecret"
                              Label="Client secret"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password" />

                <MudTextField @bind-Value="uploadOptions.Scope"
                              Label="Scope (optional)"
                              Variant="Variant.Outlined" />

                <MudDivider Class="my-2" />

                <MudText Typo="Typo.subtitle1">Logging</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Logs always go to a local rolling file (7 days kept). Add a Seq server to also ship
                    them there. Restart the app to apply changes.
                </MudText>

                <MudTextField @bind-Value="loggingOptions.SeqUrl"
                              Label="Seq server URL (optional)"
                              Placeholder="https://seq.example.com"
                              Variant="Variant.Outlined" />

                <MudTextField @bind-Value="loggingOptions.SeqApiKey"
                              Label="Seq API key (optional)"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password" />

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           OnClick="ShareLatestLog"
                           StartIcon="Icons.Material.Filled.Description">
                    Share latest log file
                </MudButton>

                <MudDivider Class="my-2" />

                @if (pendingUploads > 0)
                {
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudChip T="string" Color="Color.Warning" Icon="Icons.Material.Filled.CloudQueue">
                            @pendingUploads queued scan(s)
                        </MudChip>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="RetryQueued"
                                   Disabled="isTesting"
                                   StartIcon="Icons.Material.Filled.Replay">
                            Retry now
                        </MudButton>
                    </MudStack>
                }

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="SaveSettings"
                               StartIcon="Icons.Material.Filled.Save">
                        Save
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               OnClick="TestConnection"
                               Disabled="@(isTesting || string.IsNullOrWhiteSpace(uploadOptions.BaseUrl))"
                               StartIcon="Icons.Material.Filled.NetworkCheck">
                        Test
                    </MudButton>
                </MudStack>

                @if (isTesting)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private ApiUploadOptions uploadOptions = new();
    private LoggingOptions loggingOptions = new();
    private bool isTesting;
    private int pendingUploads;

    protected override async Task OnInitializedAsync()
    {
        uploadOptions = await ApiUploadOptions.LoadAsync();
        loggingOptions = LoggingOptions.Load();
        pendingUploads = UploadQueue.PendingCount;
    }

    private async Task ShareLatestLog()
    {
        try
        {
            var latestLog = Directory.Exists(LoggingOptions.LogDirectory)
                ? Directory.GetFiles(LoggingOptions.LogDirectory, "*.log").OrderByDescending(f => f).FirstOrDefault()
                : null;

            if (latestLog == null)
            {
                ToastService.Add("No log file yet", Severity.Info);
                return;
            }

            await Share.Default.RequestAsync(new ShareFileRequest
            {
                Title = "CheapBarcodes log",
                File = new ShareFile(latestLog)
            });
        }
        catch (Exception ex)
        {
            ToastService.Add($"Share failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task RetryQueued()
    {
        isTesting = true;
        try
        {
            await uploadOptions.SaveAsync();
            pendingUploads = await UploadQueue.TryFlushAsync(uploadOptions);
            ToastService.Add(pendingUploads == 0
                ? "Queue flushed"
                : $"{pendingUploads} scan(s) still queued", pendingUploads == 0 ? Severity.Success : Severity.Warning);
        }
        finally
        {
            isTesting = false;
        }
    }

    private async Task SaveSettings()
    {
        await uploadOptions.SaveAsync();
        loggingOptions.Save();
        ToastService.Add("Settings saved", Severity.Success);
    }

    private async Task TestConnection()
    {
        isTesting = true;
        try
        {
            // Save first so the test uses what is on screen
            await uploadOptions.SaveAsync();
            var connectionResult = await ScanApi.TestConnectionAsync(uploadOptions);
            ToastService.Add($"API responded: {connectionResult}", Severity.Info);
        }
        catch (Exception ex)
        {
            ToastService.Add($"Connection failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            isTesting = false;
        }
    }
}
